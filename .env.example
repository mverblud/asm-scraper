# ─────────────────────────────────────────────────────────
# ASM Autopartes San Martín — Variables de entorno (ejemplo)
# Copiá este archivo como .env y completá los valores
# ─────────────────────────────────────────────────────────

# Servidor
PORT=3000

# Credenciales de acceso al sitio
ASM_USERNAME=tu_usuario
ASM_PASSWORD=tu_contraseña

# URLs del sitio
ASM_BASE_URL=https://autopartessanmartin.com.ar
ASM_LOGIN_URL=https://autopartessanmartin.com.ar/cuenta/
ASM_SHOP_URL=https://autopartessanmartin.com.ar/tienda/

# Playwright
ASM_HEADLESS=true
ASM_LOGIN_TIMEOUT=30000
ASM_REQUEST_TIMEOUT=30000
ASM_MAX_RETRIES=3

# Logging (debug | info | warn | error)
LOG_LEVEL=info
