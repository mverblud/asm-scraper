									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/productos",
							"host": ["{{baseUrl}}"],
							"path": ["productos"]
						},
						"description": "Ruta que no existe. Debe retornar 404 con las rutas disponibles."
					}
				}
			]
		}
	]
}
